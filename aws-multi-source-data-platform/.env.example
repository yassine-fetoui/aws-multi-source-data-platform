# ── AWS Configuration ──────────────────────────────────────────────────────
# Never commit real values — this file is a template only
AWS_REGION=eu-west-1
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/data-platform-role

# ── S3 Buckets ─────────────────────────────────────────────────────────────
S3_RAW_BUCKET=data-platform-raw-dev
S3_CURATED_BUCKET=data-platform-curated-dev
S3_CONSUMPTION_BUCKET=data-platform-consumption-dev
TF_STATE_BUCKET=data-platform-tfstate-dev

# ── Kafka / MSK ────────────────────────────────────────────────────────────
MSK_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_TOPIC_ORDERS=orders
KAFKA_CONSUMER_GROUP=s3-sink-orders

# ── Redshift ───────────────────────────────────────────────────────────────
REDSHIFT_HOST=your-cluster.region.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=dataplatform
REDSHIFT_USER=admin
REDSHIFT_PASSWORD=CHANGE_ME   # injected from Secrets Manager in production

# ── RDS PostgreSQL ─────────────────────────────────────────────────────────
RDS_HOST=your-rds-instance.region.rds.amazonaws.com
RDS_PORT=5432
RDS_DB=dataplatform
RDS_USER=admin
RDS_PASSWORD=CHANGE_ME

# ── Local development (MinIO + PostgreSQL) ─────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
POSTGRES_DB=dataplatform
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme

# ── Airflow ────────────────────────────────────────────────────────────────
AIRFLOW_FERNET_KEY=GENERATE_WITH_python_-c_"from_cryptography.fernet_import_Fernet;print(Fernet.generate_key().decode())"
AIRFLOW_SECRET_KEY=CHANGE_ME

# ── Notifications ──────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME
